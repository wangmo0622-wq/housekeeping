# =============================================================================
# 数据库一致性（必读）
# - Django 只使用 PostgreSQL（不再使用 SQLite）；须先启动 Postgres（如 docker compose up db）。
# - 本机运行 manage.py 与 Docker 内 backend 必须使用「同一库名、同一账号密码」。
# - 凭据只维护本文件：复制为 .env 后勿在 IDE/系统里再配另一套 POSTGRES_*。
# - 本机连 Docker 映射的 Postgres：POSTGRES_HOST=localhost，端口与 compose 映射一致。
# - 核对命令：cd backend && python manage.py show_database
#
# 本机独立安装 PostgreSQL（不用 Docker 跑库）时：
# - 数据目录由 Postgres 自己管理，正常关机、重启不会丢库；勿随意删除该数据目录。
# - 定期备份，避免磁盘损坏或误删库：cd backend && bash scripts/backup_postgres.sh
#   会生成 backend/backups/jiazheng_时间戳.dump（pg_restore 可恢复到测试机或预发布）。
# - 另可用 Django 导出 JSON 基线（表多、体积大时慎用）：见下方「发布用数据快照」示例。
# =============================================================================
#
# 项目根目录 .env —— 复制为 .env 后按需修改（docker compose 与本机 manage.py 共用一套库名/账号）
# cp .env.example .env

# —— PostgreSQL（与 docker-compose 中 db 服务一致）——
POSTGRES_DB=jiazheng
POSTGRES_USER=duoduo
POSTGRES_PASSWORD=jiazheng_secret_pw
# 本机执行 python manage.py 时连宿主机映射的端口，用 localhost；Compose 内 backend 会强制使用主机名 db，不受此项影响
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# —— Django（backend 容器通过 compose 传入；本机开发也可放在此文件）——
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost,http://127.0.0.1:8000,http://localhost:8000

# Redis：本机若只起了 docker 的 redis，端口一般为 6379
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true

CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=

ENABLE_API_DOCS=true
PUBLIC_CATEGORY_TREE_CACHE_SECONDS=300

# -----------------------------------------------------------------------------
# 发布用数据快照（可选，与 backup_postgres.sh 二选一或组合使用）
# 在已激活 venv、配置好 POSTGRES_* 的前提下，于 backend 目录执行：
#
#   python manage.py dumpdata --natural-foreign --natural-primary \
#     --exclude sessions --exclude admin.logentry \
#     --indent 2 -o data/exported_data.json
#
# 导入空库或演示环境：python manage.py load_demo_export（见 accounts/management）
# 若有用户上传文件，请同步备份目录 MEDIA_ROOT（默认 backend/media）。
# -----------------------------------------------------------------------------
