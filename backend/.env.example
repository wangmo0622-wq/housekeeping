# —— 复制为 .env 后修改 —— Docker Compose 会读取本文件

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,web
# 与宿主机访问地址一致，用于 CSRF（HTTPS 部署时写完整来源）
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# 数据库（Compose 内由 db 服务提供；本地直连可改 HOST）
POSTGRES_DB=jiazheng
POSTGRES_USER=jiazheng
POSTGRES_PASSWORD=jiazheng
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis（Compose 内默认 redis://redis:6379/0）
REDIS_URL=redis://redis:6379/0
# CI / 无 Redis 时可设 false 使用内存缓存
USE_REDIS=true

# CORS：生产务必改为 false 并配置 CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL_ORIGINS=false
# 逗号分隔，例：https://servicewechat.com,https://your-admin.example.com
CORS_ALLOWED_ORIGINS=

# 是否挂载 Swagger/ReDoc（生产建议 false）
ENABLE_API_DOCS=true

# 公共分类树：服务端缓存秒数，并影响 Cache-Control（工具/真机可能跟缓存）。
# 0 = 不缓存且响应 no-store（联调推荐）；后台保存分类后会清服务端键，但清不了已缓存的客户端，需设 0 或重编译清缓存。
PUBLIC_CATEGORY_TREE_CACHE_SECONDS=300

# 对外映射端口（可选）
WEB_PUBLISH_PORT=8000
POSTGRES_PUBLISH_PORT=5432
REDIS_PUBLISH_PORT=6379
