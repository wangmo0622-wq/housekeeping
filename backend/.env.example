# Django 仅使用 PostgreSQL（与 POSTGRES_* 一致，不再使用 SQLite）。
# 推荐：使用「仓库根目录」的 .env（与 Docker Compose、本机 manage.py 共用同一数据库）
#   cp ../.env.example ../.env
#
# 若仅在 backend 目录保留覆盖项，可在此建立 .env（会覆盖根目录同名变量）：
#   cp .env.example .env

# 以下与根目录 .env.example 保持一致即可
POSTGRES_DB=jiazheng
POSTGRES_USER=duoduo
POSTGRES_PASSWORD=jiazheng_secret_pw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SiliconFlow（用于后台 AI 富文本辅助）
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_CHAT_COMPLETIONS_URL=https://api.siliconflow.cn/v1/chat/completions
